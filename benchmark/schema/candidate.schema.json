{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/brycewang-stanford/Auto-Empirical-Research-Skills/benchmark/schema/candidate.schema.json",
  "title": "AERS benchmark candidate results",
  "description": "Schema for benchmark/candidates/<run-name>/results.json. benchmark/check_benchmark.py is the authoritative validator; this schema documents the task-specific numeric fields expected from candidate pipelines.",
  "type": "object",
  "required": [
    "task"
  ],
  "additionalProperties": true,
  "properties": {
    "task": {
      "type": "string",
      "enum": [
        "bad-control-recovery",
        "bartik-recovery",
        "bayesian-recovery",
        "card-iv-recovery",
        "cate-recovery",
        "did-staggered-recovery",
        "dml-recovery",
        "event-study-recovery",
        "lalonde-recovery",
        "mediation-recovery",
        "panel-fe-recovery",
        "qte-recovery",
        "rdd-recovery",
        "survival-recovery",
        "synthetic-control-recovery"
      ]
    },
    "method": {
      "type": "string"
    },
    "n": {
      "type": "integer",
      "minimum": 0
    },
    "n_treated": {
      "type": "integer",
      "minimum": 0
    },
    "n_control": {
      "type": "integer",
      "minimum": 0
    },
    "ols_return": {
      "type": "number"
    },
    "iv_return": {
      "type": "number"
    },
    "first_stage_F": {
      "type": "number"
    },
    "first_stage_coef": {
      "type": "number"
    },
    "true_att": {
      "type": "number"
    },
    "twfe_att": {
      "type": "number"
    },
    "cs_att": {
      "type": "number"
    },
    "naive_att": {
      "type": "number"
    },
    "adjusted_att": {
      "type": "number"
    },
    "true_tau": {
      "type": "number"
    },
    "naive_jump": {
      "type": "number"
    },
    "global_att": {
      "type": "number"
    },
    "local_att": {
      "type": "number"
    },
    "true_total": {
      "type": "number"
    },
    "naive_effect": {
      "type": "number"
    },
    "good_control_effect": {
      "type": "number"
    },
    "bad_control_effect": {
      "type": "number"
    },
    "twoway_fe_att": {
      "type": "number"
    },
    "pooled_att": {
      "type": "number"
    },
    "es_att": {
      "type": "number"
    },
    "es_pre_max": {
      "type": "number"
    },
    "naive_before_after": {
      "type": "number"
    },
    "true_theta": {
      "type": "number"
    },
    "dml_theta": {
      "type": "number"
    },
    "naive_theta": {
      "type": "number"
    },
    "true_surv_treat": {
      "type": "number"
    },
    "true_surv_control": {
      "type": "number"
    },
    "km_surv_treat": {
      "type": "number"
    },
    "km_surv_control": {
      "type": "number"
    },
    "naive_surv_treat": {
      "type": "number"
    },
    "naive_surv_control": {
      "type": "number"
    },
    "data_mean": {
      "type": "number"
    },
    "posterior_weak": {
      "type": "number"
    },
    "posterior_strong": {
      "type": "number"
    },
    "true_effect": {
      "type": "number"
    },
    "sc_effect": {
      "type": "number"
    },
    "cate_low": {
      "type": "number"
    },
    "cate_high": {
      "type": "number"
    },
    "cate_gap": {
      "type": "number"
    },
    "ate_stratified": {
      "type": "number"
    },
    "naive_ate": {
      "type": "number"
    },
    "qte_50": {
      "type": "number"
    },
    "qte_90": {
      "type": "number"
    },
    "ate": {
      "type": "number"
    },
    "balance": {
      "type": "object",
      "additionalProperties": {
        "type": "number"
      }
    },
    "bartik_beta": {
      "type": "number"
    },
    "ols_beta": {
      "type": "number"
    },
    "total_effect": {
      "type": "number"
    },
    "nde": {
      "type": "number"
    },
    "nie": {
      "type": "number"
    },
    "naive_direct": {
      "type": "number"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "task": {
            "const": "card-iv-recovery"
          }
        }
      },
      "then": {
        "required": [
          "ols_return",
          "iv_return",
          "first_stage_F",
          "first_stage_coef"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "task": {
            "const": "did-staggered-recovery"
          }
        }
      },
      "then": {
        "required": [
          "true_att",
          "twfe_att",
          "cs_att"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "task": {
            "const": "lalonde-recovery"
          }
        }
      },
      "then": {
        "required": [
          "naive_att",
          "adjusted_att",
          "balance"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "task": {
            "const": "rdd-recovery"
          }
        }
      },
      "then": {
        "required": [
          "true_tau",
          "naive_jump",
          "global_att",
          "local_att"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "task": {
            "const": "bad-control-recovery"
          }
        }
      },
      "then": {
        "required": [
          "true_total",
          "naive_effect",
          "good_control_effect",
          "bad_control_effect"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "task": {
            "const": "panel-fe-recovery"
          }
        }
      },
      "then": {
        "required": [
          "true_att",
          "twoway_fe_att",
          "pooled_att"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "task": {
            "const": "event-study-recovery"
          }
        }
      },
      "then": {
        "required": [
          "true_att",
          "es_att",
          "es_pre_max",
          "naive_before_after"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "task": {
            "const": "dml-recovery"
          }
        }
      },
      "then": {
        "required": [
          "true_theta",
          "dml_theta",
          "naive_theta"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "task": {
            "const": "survival-recovery"
          }
        }
      },
      "then": {
        "required": [
          "true_surv_treat",
          "true_surv_control",
          "km_surv_treat",
          "km_surv_control",
          "naive_surv_treat",
          "naive_surv_control"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "task": {
            "const": "bayesian-recovery"
          }
        }
      },
      "then": {
        "required": [
          "data_mean",
          "posterior_weak",
          "posterior_strong"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "task": {
            "const": "synthetic-control-recovery"
          }
        }
      },
      "then": {
        "required": [
          "true_effect",
          "sc_effect",
          "naive_effect"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "task": {
            "const": "cate-recovery"
          }
        }
      },
      "then": {
        "required": [
          "cate_low",
          "cate_high",
          "cate_gap",
          "ate_stratified",
          "naive_ate"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "task": {
            "const": "qte-recovery"
          }
        }
      },
      "then": {
        "required": [
          "qte_50",
          "qte_90",
          "ate"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "task": {
            "const": "bartik-recovery"
          }
        }
      },
      "then": {
        "required": [
          "bartik_beta",
          "ols_beta",
          "first_stage_coef"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "task": {
            "const": "mediation-recovery"
          }
        }
      },
      "then": {
        "required": [
          "total_effect",
          "nde",
          "nie",
          "naive_direct"
        ]
      }
    }
  ]
}
